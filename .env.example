# Copy to .env.local and adjust values.

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/play24x"

NODE_ENV=production

# Signs admin session cookies (defaults to playx24_secret if unset — set a strong value in production)
NEXTAUTH_SECRET=playx24_secret

# Public site URL (used to decide secure cookies: https → Secure cookie)
NEXTAUTH_URL=http://213.199.46.179:3000

# Admin login (validated on server). Username is also returned to /admin for the login field default.
# If omitted, password defaults to 12345678 — override for production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=India@8801

# Web Push (VAPID). Generate keys and set these to enable true browser push.
# Works only on HTTPS (or localhost).
VAPID_SUBJECT=mailto:admin@play24x.local
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
